{
  "expo": {
    "name": "Flux",
    "slug": "flux",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "fluxapp",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fluxapp.flux"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F0F14"
      },
      "package": "com.fluxapp.flux"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "color": "#7B6EF6"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F0F14"
        }
      ],
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
